---
// §10 — Credibility. Transparency as proof: open code, live instance, npm package.
// No fabricated logos, no "trusted by thousands" — honest v0.
const tiles = [
  { t: 'Открытый код', d: 'Бэкенд, фронтенд и MCP-сервер открыты. Увидите, что именно работает.', cta: 'GitHub →', href: 'https://portalos.rutela', i: 'code', event: 'outbound-link', eventDestination: 'github', eventLocation: 'credibility' },
  { t: 'Живой экземпляр', d: 'На telawiki.com работает тот же код. Попробуйте, прежде чем брать на себя обязательства.', cta: 'Открыть →', href: 'https://tla.portalos.ru', i: 'globe', event: 'credibility-tile', eventLabel: 'live-instance' },
  { t: 'Коннектор, который можно добавить', d: 'Настоящий MCP-коннектор, отправленный в каталоги Claude и ChatGPT и версионированный вместе с бэкендом.', cta: 'Как это работает →', href: '/mcp', i: 'package', event: 'credibility-tile', eventLabel: 'mcp-connector' },
];
const icons: Record<string, string> = {
  code: 'm16 18 6-6-6-6M8 6l-6 6 6 6',
  globe: 'M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20zM2 12h20M12 2a15 15 0 0 1 0 20 15 15 0 0 1 0-20z',
  package: 'm7.5 4.27 9 5.15M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16zM3.3 7 12 12l8.7-5M12 22V12',
};
---
<section class="section">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Доверие</p>
    <h2 class="h2">Почему стоит доверять? Не стоит — читайте код и запускайте сами.</h2>
  </div>
  <div class="tgrid">
    {tiles.map((t) => (
      <a class="tile reveal-up" href={t.href} target="_blank" rel="noopener"
         data-umami-event={t.event}
         data-umami-event-destination={t.eventDestination}
         data-umami-event-location={t.eventLocation}
         data-umami-event-label={t.eventLabel}>
        <span class="tile-ic" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={icons[t.i]} /></svg>
        </span>
        <h3 class="tile-title">{t.t}</h3>
        <p class="tile-desc">{t.d}</p>
        <span class="tile-cta">{t.cta}</span>
      </a>
    ))}
  </div>
  <p class="honesty reveal-up">
    tela на стадии <strong>v0</strong> и уже пригодна к использованию. Никаких вымышленных логотипов, никаких «нам доверяют тысячи» —
    только код, рабочий экземпляр, коннектор, который можно добавить, и спецификация, которую можно прочитать.
  </p>
</section>

<style>
  .tgrid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  .tile {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    transition: border-color var(--dur) var(--ease-out), transform var(--dur) var(--ease-out);
  }
  .tile:hover { border-color: var(--brand); transform: translateY(-2px); }
  .tile-ic {
    display: grid; place-items: center;
    width: 38px; height: 38px;
    border-radius: var(--radius-sm);
    background: var(--brand-wash);
    color: var(--brand);
    border: 1px solid var(--pill-border);
  }
  .tile-title { font-family: var(--font-display); font-size: var(--text-lg); font-weight: 600; color: var(--fg); }
  .tile-desc { color: var(--fg-soft); font-size: var(--text-sm); line-height: var(--leading-normal); flex: 1; }
  .tile-cta { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--brand); }
  .honesty {
    margin-top: 1.75rem;
    max-width: var(--measure-wide);
    color: var(--fg-faint);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }
  .honesty strong { color: var(--fg-soft); }
  @media (min-width: 820px) { .tgrid { grid-template-columns: 1fr 1fr 1fr; } }
</style>
