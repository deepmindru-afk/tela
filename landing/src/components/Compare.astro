---
// §5 — Honest comparison, as a table. Not a green-tick parity matrix and not a
// wiki-parity scorecard: tela has moved past "another wiki" — it documents
// itself (Atlas) and your agents work it from Claude/ChatGPT. So each row
// centers that category difference AND concedes the one thing the alternative
// still does better. Stacks into labelled blocks on mobile.
// `slug` links the row to its full /compare/<slug> page (omitted where there's
// no single page, e.g. the "AI wikis" category row).
const rows = [
  { n: 'Notion', slug: 'notion', edge: 'Ваши документы пишут себя сами — укажите Atlas на репозиторий или Jira-проект, и он сгенерирует вики с цитатами и проверкой покрытия — в простом Markdown, который вам принадлежит, и с которым ваши агенты работают из Claude и ChatGPT. А не закрытое хранилище блоков с прикрученным чат-сайдбаром.', better: 'Базы данных, шаблоны и общая полировка на годы впереди. Нужно реляционное рабочее пространство, а не вики? Используйте Notion.' },
  { n: 'Confluence', slug: 'confluence', edge: 'Atlas превращает git-репозиторий или Jira-проект в вики с цитатами и проверкой покрытия и поддерживает её актуальность; агенты ищут и пишут в неё по смыслу; это портативный Markdown, который можно запустить самостоятельно — никакой enterprise-установки, никакого ценообразования за место.', better: 'Глубокая двусторонняя интеграция с Jira workflow (tela документирует из Jira; она не управляет Jira), гранулярные разрешения и управление в масштабе тысяч пользователей. У команд Atlassian есть причины остаться.' },
  { n: 'Obsidian', slug: 'obsidian', edge: 'Создана для команды и агентов: документы от Atlas, семантический поиск, живая совместная работа, SSO и роли, MCP-коннектор — а не хранилище для одного пользователя с ручной синхронизацией.', better: 'Локальное хранение для одного пользователя — в этом вся суть; библиотека плагинов и графовый обзор непревзойдённы. В одиночку? Сложно превзойти.' },
  { n: 'Notion AI / «ИИ»-вики', edge: 'tela создаёт вики из ваших источников и оценивает её покрытие, а затем позволяет вашему агенту извлекать и писать в неё из Claude или ChatGPT, в Markdown, который можно экспортировать — прикрученный чат-бот к вики не делает ни того, ни другого и работает только внутри их приложения.', better: 'Удобство одного вендора и полированный встроенный ассистент, без необходимости думать об эмбеддере. Если вам нужен только их чат-бот, это проще.' },
  { n: 'GitBook', slug: 'gitbook', edge: 'Atlas генерирует и поддерживает актуальность документированного кода из вашего репозитория автоматически; MCP-сервер, чтобы Claude мог искать и писать страницы нативно; полностью самостоятельный хостинг под AGPL с выводом в Markdown, который вы контролируете.', better: 'Полировка документации для разработчиков и публикация нескольких версий для библиотек с открытым кодом — его сильная сторона. Публичная документация с чистым URL? GitBook трудно превзойти.' },
  { n: 'Outline', slug: 'outline', edge: 'Atlas превращает git-репозиторий или Jira-проект в вики с цитатами и проверкой покрытия и автоматически поддерживает её актуальность; семантический поиск и ответы по документам с цитированием абзацев; MCP-сервер, чтобы агенты были полноправными членами команды наравне с людьми.', better: 'Полированная, хорошо поддерживаемая вики с сильным сообществом и чистым интерфейсом. Если вам нужна отличная вики без ИИ-генерации, Outline превосходна.' },
];
---
<section id="compare" class="section">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Сравнение</p>
    <h2 class="h2">Не просто очередная вики.</h2>
    <p class="lede">tela документирует сама себя, а ваши агенты работают с ней из Claude и ChatGPT — поэтому честный вопрос не «какая вики», а чем она отличается от каждого инструмента, который вы иначе рассматривали бы, и что каждый из них всё ещё делает лучше.</p>
  </div>

  <div class="cmp-wrap reveal-up">
    <table class="cmp">
      <thead>
        <tr>
          <th scope="col" class="col-name">Сравнение с</th>
          <th scope="col" class="col-edge">Где tela выигрывает</th>
          <th scope="col" class="col-better">Что он всё ещё делает лучше</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr>
            <th scope="row" class="cmp-name">
              {r.n}
              {r.slug && <a class="cmp-more" href={`/compare/${r.slug}/`}>Полное сравнение →</a>}
            </th>
            <td class="cmp-edge" data-label="Где tela выигрывает">
              <svg class="tick" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
              <span>{r.edge}</span>
            </td>
            <td class="cmp-better" data-label="Всё ещё делает лучше">{r.better}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p class="synth reveal-up">
    Ни один из них не замыкает тот цикл, что делает tela: ваши источники становятся вики с цитатами и проверкой покрытия,
    ваши агенты работают с ней и поддерживают её из Claude и ChatGPT, и всё это в простом Markdown,
    который вам принадлежит — с редактированием в реальном времени и ролями, а также SSO и аудитом в Enterprise.
  </p>
</section>

<style>
  .cmp-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface);
  }
  .cmp {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }
  .cmp thead th {
    text-align: left;
    padding: 0.85rem 1.1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 500;
    background: var(--surface-sunk);
    border-bottom: 1px solid var(--border);
    vertical-align: bottom;
  }
  .cmp thead .col-edge { color: var(--brand); }
  .cmp thead .col-name,
  .cmp thead .col-better { color: var(--fg-faint); }

  .cmp tbody tr { border-bottom: 1px solid var(--border); }
  .cmp tbody tr:last-child { border-bottom: 0; }
  .cmp td,
  .cmp tbody th { padding: 1rem 1.1rem; vertical-align: top; text-align: left; }

  .cmp-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--fg);
    width: 18%;
    min-width: 8rem;
  }
  .cmp-more {
    display: block;
    margin-top: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--brand);
    text-decoration: none;
  }
  .cmp-more:hover { color: var(--brand-strong); text-decoration: underline; }
  .cmp-edge {
    color: var(--fg);
    width: 45%;
    background: var(--brand-wash);
    border: 1px solid var(--pill-border);
  }
  .cmp-edge span { display: inline; }
  .cmp-edge .tick {
    color: var(--brand);
    display: inline-block;
    vertical-align: -2px;
    margin-right: 0.35rem;
  }
  .cmp-better { color: var(--fg-faint); width: 37%; }

  .synth {
    margin-top: 1.75rem;
    max-width: 64ch;
    margin-inline: auto;
    text-align: center;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
    color: var(--fg-soft);
    letter-spacing: var(--tracking-tight);
  }
  .synth strong { color: var(--fg); font-weight: 600; }

  /* ── Mobile: stack each row into a labelled block ─────────────────────── */
  @media (max-width: 720px) {
    .cmp-wrap { border: 0; background: transparent; overflow: visible; }
    .cmp thead { position: absolute; width: 1px; height: 1px; overflow: hidden; clip-path: inset(50%); }
    .cmp, .cmp tbody, .cmp tr, .cmp td, .cmp tbody th { display: block; width: auto; }
    .cmp tr {
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      background: var(--surface);
      margin-bottom: 0.85rem;
      overflow: hidden;
    }
    .cmp-name {
      font-size: var(--text-lg);
      padding: 0.9rem 1.1rem 0.6rem;
      border-bottom: 1px solid var(--border);
      min-width: 0;
    }
    .cmp-edge, .cmp-better { border: 0; }
    .cmp td::before {
      content: attr(data-label);
      display: block;
      margin-bottom: 0.3rem;
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .cmp-edge::before { color: var(--brand); }
    .cmp-better::before { color: var(--fg-faint); }
  }
</style>
