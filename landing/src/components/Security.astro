---
// §8 — Security & team. The trust pillar that replaces the old self-host pillar.
// SSO, orgs + groups, per-space RBAC, scoped + audited keys, hardened import.
// Ends with the short self-host escape hatch (demoted, present, not headline).
const tiles = [
  { t: 'Общеорганизационный, групповой или личный', d: 'Поделитесь пространством со всей организацией, ограничьте его одной группой или оставьте личным.', accent: false },
  { t: 'Агенты не выходят за рамки', d: 'Агент в Claude или ChatGPT видит только то, что видит ваша учётная запись. Он не может получить доступ к пространству, где вас нет.', accent: true },
  { t: 'Роли в каждом пространстве', d: 'Дайте каждому доступ владельца, редактора или зрителя. Доступ можно добавлять, но нельзя бесшумно понижать.', accent: false },
  { t: 'Единый вход (SSO)', d: 'Вход через SAML/OIDC SSO, который ваша команда уже использует (Enterprise). Учётные записи подтверждаются по email.', accent: false },
  { t: 'Ограниченные ключи агентов', d: 'Для агентов — каждый ключ только для чтения или для записи, может истекать и быть привязан к одному пространству.', accent: false },
  { t: 'Общий доступ с паролем', d: 'Публичные ссылки могут требовать пароль и дату истечения. Каждый запрос ключа логируется.', accent: false },
];
---
<section id="security" class="section">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Безопасность и команда</p>
    <h2 class="h2">Создано для команды, которой можно доверять.</h2>
    <p class="lede">
      Каждым пространством можно поделиться со всей организацией, открыть для конкретной команды или
      оставить личным. Участники получают доступ владельца, редактора или зрителя — и <strong>агент, подключённый
      через Claude или ChatGPT, видит только то, что доступно вашей учётной записи</strong>.
    </p>
  </div>

  <div class="sec-grid reveal-up">
    {tiles.map((t) => (
      <div class:list={['sec-tile', { accent: t.accent }]}>
        <span class="sec-dot" aria-hidden="true"></span>
        <h3 class="sec-t" set:html={t.t}></h3>
        <p class="sec-d" set:html={t.d}></p>
      </div>
    ))}
  </div>

  <div class="selfhost reveal-up">
    <div class="sh-copy">
      <h3 class="sh-t">Разместите сами, если хотите</h3>
      <p class="sh-d">
        tela — это открытое ПО, работающее на вашем сервере через Docker Compose — ваш Postgres, ваш
        диск, ваши данные. Самостоятельный хостинг необязателен; хостированный экземпляр готов к использованию.
      </p>
      <a class="sh-link" href="https://github.com/zcag/tela#readme" target="_blank" rel="noopener">Читать документацию →</a>
    </div>
    <pre class="sh-code" tabindex="0" aria-label="быстрый старт самостоятельного хостинга"><code><span class="c"># ваш сервер, ваши данные</span>
cp deploy/.env.example deploy/.env
docker compose up</code></pre>
  </div>

  <p class="sec-honest reveal-up">
    Честные оговорки: организации настраиваются администратором (не открытая самостоятельная регистрация), а социальный вход
    пока не реализован — по замыслу. Модель доступа документирована, а код аутентификации открыт.
  </p>
</section>

<style>
  .section-head .lede strong { color: var(--fg); font-weight: 600; }

  .sec-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }
  .sec-tile {
    position: relative;
    padding: 1.25rem 1.3rem 1.3rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }
  .sec-dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: var(--radius-full);
    background: var(--brand);
    box-shadow: 0 0 0 3px var(--brand-wash);
    margin-bottom: 0.85rem;
  }
  .sec-tile.accent {
    border-color: var(--brand);
    background: var(--brand-wash);
  }
  .sec-tile.accent .sec-dot { background: var(--brand-strong); box-shadow: 0 0 0 3px color-mix(in oklab, var(--brand) 22%, transparent); }
  .sec-t {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
  }
  .sec-d { margin-top: 0.4rem; font-size: var(--text-sm); color: var(--fg-soft); line-height: var(--leading-normal); }

  .selfhost {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: center;
    padding: 1.5rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    background: var(--surface-sunk);
  }
  .sh-t {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
  }
  .sh-d { margin-top: 0.6rem; max-width: var(--measure); color: var(--fg-soft); font-size: var(--text-base); line-height: var(--leading-normal); }
  .sh-link { display: inline-block; margin-top: 1rem; color: var(--brand); font-size: var(--text-base); }
  .sh-link:hover { color: var(--brand-strong); text-decoration: underline; }
  .sh-code {
    margin: 0;
    padding: 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.85;
    color: var(--fg);
    overflow-x: auto;
  }
  .sh-code .c { color: var(--fg-faint); }

  .sec-honest {
    margin-top: 1.5rem;
    max-width: var(--measure-wide);
    color: var(--fg-faint);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  @media (min-width: 720px) {
    .sec-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 960px) {
    .sec-grid { grid-template-columns: 1fr 1fr 1fr; }
    .selfhost { grid-template-columns: 1.1fr 0.9fr; gap: 2rem; }
  }
</style>
