<script>
  // The signature moment. Self-contained, guarded by reduced-motion + an
  // IntersectionObserver so it only plays when scrolled into view, once.
  // SSR renders both chats full + the finished page; JS replays it on scroll,
  // revealing each turn in BOTH app windows in sync and weaving the page when
  // the commit turn lands.
  const section = document.querySelector<HTMLElement>('[data-agentweave]');
  if (section) {
    const chats = Array.from(section.querySelectorAll<HTMLElement>('[data-chat]'));
    const loom = section.querySelector<HTMLElement>('.loomwrap');
    const lines = Array.from(section.querySelectorAll<HTMLElement>('[data-line]'));
    // one panel's turns drive the timeline; both panels are identical
    const steps = chats[0] ? Array.from(chats[0].querySelectorAll<HTMLElement>('[data-turn]')) : [];
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));

    async function play() {
      if (!steps.length) return;
      section.classList.add('is-animating');
      chats.forEach((c) => c.classList.add('playing'));
      for (let i = 0; i < steps.length; i++) {
        const isTool = steps[i].classList.contains('tool');
        await wait(isTool ? 520 : 760);
        section.querySelectorAll<HTMLElement>(`[data-idx="${i}"]`).forEach((t) => t.classList.add('show'));
        if (steps[i].dataset.commit === 'true') {
          loom?.classList.add('is-weaving');
          const step = 1600 / Math.max(lines.length, 1);
          lines.forEach((l, j) => setTimeout(() => l.classList.add('lit'), j * step));
          await wait(1500);
        }
      }
    }

    if (!reduce) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { io.disconnect(); play(); }
        }
      }, { threshold: 0.35 });
      io.observe(section);
    }
  }
</script>
