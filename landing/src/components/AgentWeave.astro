---
// AgentWeave — the carved-out signature moment (motion-throttle-exempt).
// Top: the SAME wiki exchange shown in two faithful, instantly-recognizable
// app windows — Claude and ChatGPT — so "Already in Claude and ChatGPT" reads
// at a glance. Below: tela's editor, where the loom threads sweep and the page
// materializes as the assistant commits an edit. Reads in <5s as "the AI is
// using the wiki from the apps I already use, not chatting about it." No JSON,
// no code: the user never sees a raw tool call. Reduced-motion / no-JS render
// the resolved frame. The app-window chrome uses --ext-* skin tokens (honest,
// recognizable approximations — nominative fair use, not pixel-cloned).
import EditorMock from './EditorMock.astro';

// The chat turns, exactly as they'd appear in the chat app. `tool` turns are the
// small "used a connector" indicators; the one flagged `commit` triggers the
// page weave. The same conversation is shown in both windows — same connector,
// same wiki, both apps.
const turns = [
  { who: 'user', text: 'What are the rollback steps for an incident?' },
  { who: 'tool', text: 'Searched the wiki — Incident response' },
  { who: 'bot',  text: 'Revert the image tag, re-probe /api/version, then purge the edge cache. Source: Incident response → Rollback.' },
  { who: 'user', text: 'Add a note to purge the cache first.' },
  { who: 'tool', text: 'Updated Incident response', commit: true },
  { who: 'bot',  text: 'Done — added it under Rollback.' },
];

// Claude's clay sunburst, drawn as radial spokes (recognizable, not cloned).
const claudeRays = Array.from({ length: 12 }, (_, i) => {
  const a = (i / 12) * Math.PI * 2;
  return {
    x1: +(12 + Math.cos(a) * 3).toFixed(2),
    y1: +(12 + Math.sin(a) * 3).toFixed(2),
    x2: +(12 + Math.cos(a) * 9.4).toFixed(2),
    y2: +(12 + Math.sin(a) * 9.4).toFixed(2),
  };
});

// The two app windows, each with its skin class + display name + connector verb.
const apps = [
  { skin: 'claude', name: 'Claude', composer: 'Reply to Claude…' },
  { skin: 'gpt',    name: 'ChatGPT', composer: 'Message ChatGPT' },
];

// real tool catalog (subset shown, grouped by scope) — names from internal/api/mcp_tools.go
const toolScopes = [
  { scope: 'read', tone: 'read', tools: ['research', 'search', 'read_chunk', 'related_pages', 'suggest_links', 'get_page', 'list_pages', 'list_backlinks', 'atlas_list_projects', 'atlas_run_status'] },
  { scope: 'write', tone: 'write', tools: ['create_page', 'update_page', 'add_comment', 'move_page'] },
  { scope: 'admin', tone: 'admin', tools: ['create_space', 'update_space', 'manage keys', 'atlas_run'] },
];

// how you connect the chat apps — no install, no local proxy
const connectSteps = [
  { n: '1', t: 'Add a connector', d: 'In Claude or ChatGPT, add tela as a connector.', code: 'tela.cagdas.io/api/mcp' },
  { n: '2', t: 'Sign in', d: 'One sign-in with your tela account. No token to paste.', code: 'OAuth 2.1' },
  { n: '3', t: 'Use it', d: 'The assistant searches and edits the wiki, within your permissions.', code: '39 tools' },
];
---

<section id="agents" class="agentweave" data-agentweave>
  <div class="head">
    <p class="eyebrow"><span class="eyebrow-dot"></span>The agent layer</p>
    <h2 class="title">Already in Claude and ChatGPT.</h2>
    <p class="lede">
      Your AI already lives in the chat apps you work in, so tela connects to them — instead of
      bolting a chat box onto a wiki you'd have to go open. Connect once and the assistant searches
      your docs, reads and writes pages, and adds comments, limited to what your account can access.
      Below: the same wiki, answered and edited from both apps — the connector does the work, you
      never leave the chat.
    </p>
  </div>

  <div class="stage">
    <!-- TOP: the same exchange, in two recognizable app windows -->
    <div class="chatpair">
      {apps.map((app) => (
        <div class:list={['appwin', app.skin]}>
          <div class="aw-top">
            <span class="aw-mark">
              {app.skin === 'claude'
                ? <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">{claudeRays.map((r) => <line x1={r.x1} y1={r.y1} x2={r.x2} y2={r.y2} />)}</svg>
                : <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.998-2.9 6.056 6.056 0 0 0-.748-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.142-.08 4.778-2.758a.795.795 0 0 0 .393-.681v-6.737l2.02 1.168a.07.07 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zM8.307 12.863l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365 2.602-1.5 2.607 1.5v3l-2.597 1.5-2.607-1.5z"/></svg>}
            </span>
            <span class="aw-name">{app.name}</span>
            <span class="aw-conn"><span class="aw-conn-dot"></span>tela connected</span>
          </div>

          <div class="aw-chat" data-chat aria-hidden="true">
            {turns.map((t, i) => (
              t.who === 'tool' ? (
                <div class="aw-turn tool" data-turn data-idx={i} data-commit={t.commit ? 'true' : 'false'}>
                  <span class="aw-tool">
                    {t.commit
                      ? <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>
                      : <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>}
                    {t.text}
                  </span>
                </div>
              ) : t.who === 'user' ? (
                <div class="aw-turn user" data-turn data-idx={i}>
                  <span class="aw-bubble user">{t.text}</span>
                </div>
              ) : (
                <div class="aw-turn bot" data-turn data-idx={i}>
                  <span class="aw-av">
                    {app.skin === 'claude'
                      ? <svg viewBox="0 0 24 24" width="13" height="13" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">{claudeRays.map((r) => <line x1={r.x1} y1={r.y1} x2={r.x2} y2={r.y2} />)}</svg>
                      : <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor" aria-hidden="true"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.998-2.9 6.056 6.056 0 0 0-.748-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.142-.08 4.778-2.758a.795.795 0 0 0 .393-.681v-6.737l2.02 1.168a.07.07 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zM8.307 12.863l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681z"/></svg>}
                  </span>
                  <span class="aw-text">{t.text}</span>
                </div>
              )
            ))}
          </div>

          <div class="aw-composer">
            <span class="aw-ph">{app.composer}</span>
            <span class="aw-send" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5"/><path d="m5 12 7-7 7 7"/></svg>
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- BELOW: the wiki the agent is weaving -->
    <div class="loomwrap">
      <div class="sweep" data-sweep aria-hidden="true"></div>
      <EditorMock staged class="loom-editor" />
    </div>
  </div>

  <!-- the connect flow — the whole integration -->
  <div class="connect reveal-up">
    <ol class="connect-steps">
      {connectSteps.map((s) => (
        <li class="cstep">
          <span class="cs-n">{s.n}</span>
          <div class="cs-body">
            <h3 class="cs-t">{s.t}</h3>
            <p class="cs-d">{s.d}</p>
            <code class="cs-code">{s.code}</code>
          </div>
        </li>
      ))}
    </ol>
    <p class="connect-cap">Available in the <strong>Claude</strong> and <strong>ChatGPT</strong> connector directories. Nothing to install.</p>
    <p class="codeagents">Using Claude Code, Cursor, or your own client? Connect to the same address: <code>tela.cagdas.io/api/mcp</code>.</p>
  </div>

  <!-- the tool catalog, grouped by scope -->
  <div class="tools reveal-up">
    <div class="tools-head">
      <h3 class="tools-title">39 tools, grouped by access</h3>
      <p class="tools-sub">Give an agent a read-only key, or one that can write. A key can be pinned to a single space.</p>
    </div>
    <div class="tools-grid">
      {toolScopes.map((g) => (
        <div class="scope">
          <span class:list={['scope-tag', g.tone]}>{g.scope}</span>
          <ul class="scope-tools">
            {g.tools.map((t) => <li><code>{t}</code></li>)}
          </ul>
        </div>
      ))}
    </div>
    <p class="tools-why">
      The assistant reads from the wiki and writes back to it, so context carries from one session
      to the next instead of being pasted in each time. It can also surface related pages, suggest
      links while writing, and flag overlapping content — and even kick off an Atlas run and check
      its status — so the knowledge base stays connected and current as it grows.
    </p>
    <a class="tools-link" href="/mcp/">See the full tool catalog →</a>
  </div>
</section>

<style>
  .agentweave {
    max-width: var(--col-max);
    margin-inline: auto;
    padding: var(--section-y) var(--space-gutter);
    scroll-margin-top: 5rem;
  }

  .head { max-width: 46rem; }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-kicker);
    color: var(--brand);
    margin-bottom: 1rem;
  }
  .eyebrow-dot { width: 6px; height: 6px; border-radius: var(--radius-full); background: var(--brand); box-shadow: var(--glow-brand); }
  .title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: var(--tracking-display);
    line-height: var(--leading-snug);
    color: var(--fg);
  }
  .lede {
    margin-top: 1.1rem;
    font-size: var(--text-lg);
    color: var(--fg-soft);
    max-width: var(--measure);
  }
  .lede strong { color: var(--fg); font-weight: 600; }

  .stage {
    margin-top: 2.75rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }

  /* the two app windows, side by side */
  .chatpair {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  /* ── faithful app-window chrome (skin tokens, theme-independent) ──────── */
  .appwin {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-frame);
    min-height: 372px;
    /* a different typeface from tela's, so it reads as "another app" */
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }
  .aw-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: 42px;
    padding: 0 0.85rem;
    border-bottom: 1px solid;
  }
  .aw-mark { display: inline-flex; align-items: center; }
  .aw-name { font-weight: 600; font-size: 0.92rem; letter-spacing: -0.01em; }
  .aw-conn {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    padding: 0.18rem 0.5rem;
    border: 1px solid;
    border-radius: var(--radius-full);
  }
  .aw-conn-dot { width: 6px; height: 6px; border-radius: var(--radius-full); background: var(--ext-ok); }

  .aw-chat {
    flex: 1;
    padding: 0.95rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    overflow: hidden;
  }
  .aw-turn { display: flex; max-width: 100%; }
  .aw-turn.user { justify-content: flex-end; }
  .aw-turn.bot { gap: 0.55rem; align-items: flex-start; }
  .aw-bubble.user {
    max-width: 86%;
    font-size: 0.82rem;
    line-height: 1.45;
    padding: 0.5rem 0.75rem;
  }
  .aw-av {
    flex: none;
    width: 24px; height: 24px;
    border-radius: var(--radius-full);
    display: grid; place-items: center;
    margin-top: 1px;
  }
  .aw-text { font-size: 0.82rem; line-height: 1.5; }
  .aw-turn.tool { justify-content: flex-start; }
  .aw-tool {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
  }
  .aw-tool svg { flex: none; }

  .aw-composer {
    display: flex;
    align-items: center;
    margin: 0 0.85rem 0.85rem;
    padding: 0.5rem 0.5rem 0.5rem 0.85rem;
    border: 1px solid;
  }
  .aw-ph { font-size: 0.8rem; }
  .aw-send {
    margin-left: auto;
    width: 26px; height: 26px;
    border-radius: var(--radius-full);
    display: grid; place-items: center;
    flex: none;
  }

  /* Claude — warm paper, clay sunburst, plain-text replies */
  .appwin.claude { background: var(--ext-claude-bg); border: 1px solid var(--ext-claude-border); }
  .appwin.claude .aw-top { background: var(--ext-claude-panel); border-bottom-color: var(--ext-claude-border); }
  .appwin.claude .aw-mark { color: var(--ext-claude-clay); }
  .appwin.claude .aw-name { color: var(--ext-claude-fg); }
  .appwin.claude .aw-conn { color: var(--ext-claude-fg-soft); border-color: var(--ext-claude-border); background: var(--ext-claude-bg); }
  .appwin.claude .aw-bubble.user {
    background: var(--ext-claude-user-bg);
    border: 1px solid var(--ext-claude-border);
    color: var(--ext-claude-fg);
    border-radius: 14px;
    border-bottom-right-radius: var(--radius-xs);
  }
  .appwin.claude .aw-av { color: var(--ext-claude-clay); }
  .appwin.claude .aw-text { color: var(--ext-claude-fg); }
  .appwin.claude .aw-tool { color: var(--ext-claude-fg-soft); }
  .appwin.claude .aw-tool svg { color: var(--ext-claude-clay); }
  .appwin.claude .aw-composer { border-color: var(--ext-claude-border); background: var(--ext-claude-panel); border-radius: 13px; }
  .appwin.claude .aw-ph { color: var(--ext-claude-fg-soft); }
  .appwin.claude .aw-send { background: var(--ext-claude-clay); color: var(--ext-claude-panel); }

  /* ChatGPT — near-white, gray user bubble, black blossom mark */
  .appwin.gpt { background: var(--ext-gpt-bg); border: 1px solid var(--ext-gpt-border); }
  .appwin.gpt .aw-top { background: var(--ext-gpt-panel); border-bottom-color: var(--ext-gpt-border); }
  .appwin.gpt .aw-mark { color: var(--ext-gpt-logo); }
  .appwin.gpt .aw-name { color: var(--ext-gpt-fg); }
  .appwin.gpt .aw-conn { color: var(--ext-gpt-fg-soft); border-color: var(--ext-gpt-border); background: var(--ext-gpt-bg); }
  .appwin.gpt .aw-bubble.user {
    background: var(--ext-gpt-user-bg);
    color: var(--ext-gpt-fg);
    border-radius: 18px;
  }
  .appwin.gpt .aw-av { color: var(--ext-gpt-logo); }
  .appwin.gpt .aw-text { color: var(--ext-gpt-fg); }
  .appwin.gpt .aw-tool { color: var(--ext-gpt-fg-soft); }
  .appwin.gpt .aw-tool svg { color: var(--ext-gpt-fg-soft); }
  .appwin.gpt .aw-composer { border-color: var(--ext-gpt-border); background: var(--ext-gpt-bg); border-radius: var(--radius-full); }
  .appwin.gpt .aw-ph { color: var(--ext-gpt-fg-soft); }
  .appwin.gpt .aw-send { background: var(--ext-gpt-logo); color: var(--ext-gpt-bg); }

  /* sequential reveal (only while the signature is playing; SSR shows all) */
  .aw-turn { transition: opacity var(--dur) var(--ease-out), transform var(--dur) var(--ease-out); }
  .aw-chat.playing .aw-turn { opacity: 0; transform: translateY(8px); }
  .aw-chat.playing .aw-turn.show { opacity: 1; transform: none; }

  /* loom (editor + sweep) */
  .loomwrap { position: relative; min-width: 0; }
  .loom-editor { position: relative; z-index: 1; }
  .sweep {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    border-radius: var(--radius-lg);
    opacity: 0;
    background:
      repeating-linear-gradient(
        to right,
        var(--weave-thread) 0,
        var(--weave-thread) 1px,
        transparent 1px,
        transparent var(--weave-cell)
      );
    -webkit-mask-image: linear-gradient(to right, transparent, #000 8%, #000 12%, transparent 22%);
    mask-image: linear-gradient(to right, transparent, #000 8%, #000 12%, transparent 22%);
    -webkit-mask-size: 460% 100%;
    mask-size: 460% 100%;
    -webkit-mask-position: 0% 0;
    mask-position: 0% 0;
  }
  .loomwrap.is-weaving .sweep {
    opacity: 0.9;
    animation: sweep var(--dur-weave) var(--ease-in-out) forwards;
  }
  @keyframes sweep {
    0%   { -webkit-mask-position: 0% 0;   mask-position: 0% 0;   opacity: 0; }
    8%   { opacity: 0.9; }
    92%  { opacity: 0.9; }
    100% { -webkit-mask-position: 100% 0; mask-position: 100% 0; opacity: 0; }
  }

  /* connect flow — three steps, the whole integration */
  .connect { margin-top: 1.75rem; }
  .connect-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  .cstep {
    display: flex;
    gap: 0.85rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }
  .cs-n {
    flex: none;
    width: 26px; height: 26px;
    display: grid; place-items: center;
    border-radius: var(--radius-full);
    background: var(--brand-wash);
    border: 1px solid var(--pill-border);
    color: var(--brand);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
  }
  .cs-body { min-width: 0; }
  .cs-t {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--fg);
    letter-spacing: var(--tracking-tight);
  }
  .cs-d { margin-top: 0.25rem; font-size: var(--text-sm); color: var(--fg-soft); line-height: var(--leading-normal); }
  .cs-code {
    display: inline-block;
    margin-top: 0.55rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-soft);
    background: var(--surface-sunk);
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: 0.2rem 0.5rem;
    max-width: 100%;
    overflow-x: auto;
    white-space: nowrap;
  }
  .connect-cap {
    margin-top: 0.9rem;
    font-size: var(--text-sm);
    color: var(--fg-faint);
