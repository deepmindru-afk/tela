---
// SelfHostPricing — the editions detail, shown ONLY on the dedicated /pricing page
// (the on-page Pricing section carries just the cloud ladder). Implements the model in
// docs/editions-and-pricing.md: the two-axis story (where it runs decides the AI; which
// edition decides the company-layer), the self-host edition cards (Community / Enterprise
// / Commercial license), the cloud-vs-self-host matrix, and the core-vs-Enterprise line.
// Honest: self-host is BYO AI on EVERY edition; Community is the whole product, free.
const CONTACT_EMAIL = 'tela@telawiki.com';
const GITHUB_URL = 'https://github.com/zcag/tela';
const mailto = (subject) => `mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent(subject)}`;

// Self-host editions — TWO tiers only (the GitLab/open-core shape): the free
// Community core, and the paid Enterprise layer unlocked by a license key. The
// Commercial license (AGPL relief) is a real revenue lever but a lawyer's SKU,
// not a product tier — it lives in a strip below, not as a co-equal card.
const editions = [
  {
    name: 'Community',
    price: 'Бесплатно',
    period: 'AGPL-3.0, навсегда',
    blurb: 'Весь продукт, на вашей инфраструктуре.',
    specs: [
      'Полная вики, Atlas, поиск, агенты, таблицы, презентации и синхронизация',
      'Безлимитные пользователи, пространства и страницы',
      'Свой ИИ — любой совместимый с OpenAI LLM + эмбеддер',
      'Организации и роли по пространствам',
      'Самостоятельная поддержка, помощь сообщества',
    ],
    cta: 'Получить код',
    href: GITHUB_URL,
    action: 'github',
    featured: false,
  },
  {
    name: 'Enterprise',
    price: '$8',
    period: 'за место / мес, оплата ежегодно',
    blurb: 'Идентичность, управление и поддержка, которые нужны компании — цена места Team, на ваших серверах, с разблокировкой по лицензионному ключу.',
    specs: [
      'Всё, что есть в Community',
      'SSO / SAML / OIDC, SCIM-провижининг',
      'Журнал аудита, продвинутый RBAC, ретеншн',
      'Премиум-коннекторы Atlas (Slack, Drive, GitHub…)',
      'Приоритетная поддержка + SLA',
    ],
    cta: 'Получить лицензию',
    href: 'https://tla.portalos.ru/settings?tab=licenses',
    action: 'app',
    featured: true,
  },
];

// The reconciler: ONE product, two tiers (rows), two ways to run it (cols). This
// is the table that kills the confusion — it shows Enterprise is the same feature
// layer whether we host it or you do, and that everything below it is free to
// self-host. Cloud costs more because it bundles managed AI + ops.
const matrix = {
  cols: ['tela Cloud — мы хостим · ИИ включён', 'Самостоятельно — вы хостите · свой ИИ'],
  rows: [
    {
      label: 'Ядро',
      sub: 'вся вики + Atlas + ИИ',
      cloud: 'Free · Personal · Team',
      self: 'Community — бесплатно',
    },
    {
      label: 'Enterprise',
      sub: 'SSO · SCIM · аудит · управление',
      cloud: 'Cloud Enterprise — давайте поговорим',
      self: '$8 / место · лицензионный ключ',
    },
  ],
};

// Core vs Enterprise — what's free vs key-gated. ✓ / — rendered as marks.
const featureRows = [
  { f: 'Вики, редактор, история, свойства страниц', core: true, ent: true },
  { f: 'Совместное редактирование, таблицы, презентации, синхронизация WebDAV, MCP', core: true, ent: true },
  { f: 'Atlas, «Спросите документы», семантический поиск', core: true, ent: true },
  { f: 'Публичные пространства, кастомные домены', core: true, ent: true },
  { f: 'Организации и роли по пространствам', core: true, ent: true },
  { f: 'SSO / SAML / OIDC', core: false, ent: true },
  { f: 'SCIM-провижининг', core: false, ent: true },
  { f: 'Журнал аудита', core: false, ent: true },
  { f: 'Продвинутый RBAC / кастомные роли / ретеншн', core: false, ent: true },
  { f: 'Премиум-коннекторы Atlas (Slack, Drive, GitHub, Confluence)', core: false, ent: true },
  { f: 'HA / кластеризация, white-label', core: false, ent: true },
  { f: 'Приоритетная поддержка + SLA', core: false, ent: true },
];

const faqs = [
  {
    q: 'Нужно ли платить за ИИ при самостоятельном хостинге?',
    a: 'Нет — самостоятельный хостинг подразумевает собственный ИИ на любом выпуске, Community и Enterprise. Укажите tela любой совместимый с OpenAI LLM и совместимый с Ollama эмбеддер; инференс — ваш. Управляемый включённый ИИ — это то, за что вы платите в облачных планах.',
  },
  {
    q: 'В чём разница между Cloud Enterprise и самостоятельным Enterprise?',
    a: 'Тот же функциональный слой — SSO, SCIM, аудит, продвинутые роли, управление, поддержка. В облаке он включён в подписку, и мы его эксплуатируем (с управляемым ИИ). При самостоятельном хостинге это лицензионный ключ на вашей инфраструктуре, и вы используете свой ИИ.',
  },
  {
    q: 'Это AGPL — разве я не могу просто удалить функции Enterprise сам?',
    a: 'Enterprise живёт в отдельном проприетарном модуле, который работает только с лицензионным ключом — он не является частью открытого ядра. Открытое ядро (всё, что есть в Community) по-настоящему ваше по лицензии AGPL; Enterprise — это часть, которую вы лицензируете.',
  },
  {
    q: 'Зачем мне платить, если Community — это весь продукт?',
    a: 'Вы не платите за программное обеспечение — вы платите за управляемый ИИ + нулевую эксплуатацию (облако), или за SSO, управление и контракт поддержки (Enterprise), или за освобождение от copyleft AGPL (коммерческая лицензия). Вики и возможности ИИ никогда не являются платной стеной.',
  },
];
---
<section id="self-host" class="section sh">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Самостоятельный хостинг</p>
    <h2 class="h2">Запустите сами — бесплатно.</h2>
    <p class="lede">
      portal — open source, и весь продукт <strong>бесплатен для самостоятельного хостинга</strong> —
      безлимитные люди, на вашей инфраструктуре, с вашим ИИ. Вы платите только
      за <strong>уровень Enterprise</strong>: идентичность, управление и поддержка, которые
      нужны компании, с разблокировкой по лицензионному ключу. <strong>Всё ниже Enterprise бесплатно
      для самостоятельного хостинга, навсегда.</strong>
    </p>
  </div>

  <div class="sh-cards reveal-up">
    {editions.map((e) => (
      <article class={`sh-card${e.featured ? ' sh-card--featured' : ''}`}>
        <header class="sh-head">
          <h3 class="sh-name">{e.name}</h3>
          {e.featured ? <span class="sh-tag">Самый популярный</span> : null}
        </header>
        <p class="sh-amount">
          <span class="sh-amt">{e.price}</span>
          <span class="sh-period">{e.period}</span>
        </p>
        <p class="sh-blurb">{e.blurb}</p>
        <ul class="sh-specs">
          {e.specs.map((s) => <li>{s}</li>)}
        </ul>
        <a
          href={e.href}
          class={e.featured ? 'sh-cta sh-cta--primary' : 'sh-cta'}
          target={e.action === 'github' ? '_blank' : undefined}
          rel={e.action === 'github' ? 'noopener' : undefined}
        >{e.cta}</a>
      </article>
    ))}
  </div>

  <p class="sh-commercial reveal-up">
    <span class="sh-commercial-label">Коммерческая лицензия</span>
    Не можете использовать AGPL? Фиксированная годовая коммерческая лицензия даёт вам полное открытое ядро на
    коммерческих условиях — без copyleft-обязательств, без ограничений функций — для юридических или комплаенс-ограничений,
    даже если вы никогда не используете Enterprise.
    <a href={mailto('tela commercial license')} class="sh-commercial-link">Свяжитесь с нами&nbsp;→</a>
  </p>

  <div class="sh-matrix reveal-up">
    <p class="sh-block-label">Один продукт · два тарифа · два способа запуска</p>
    <div class="sh-table-wrap">
      <table class="sh-table sh-table--map">
        <thead>
          <tr>
            <td class="sh-corner"></td>
            {matrix.cols.map((c) => <th scope="col">{c}</th>)}
          </tr>
        </thead>
        <tbody>
          {matrix.rows.map((r) => (
            <tr>
              <th scope="row">{r.label} <span class="sh-row-sub">{r.sub}</span></th>
              <td>{r.cloud}</td>
              <td>{r.self}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="sh-note">Цена облака основана на управляемом ИИ + местах; самостоятельный хостинг бесплатен, потому что вы используете свой ИИ и инфраструктуру. <strong>Enterprise — тот же функциональный слой в обоих случаях</strong> — вы просто выбираете, кто его эксплуатирует.</p>
  </div>

  <div class="sh-features reveal-up">
    <p class="sh-block-label">Что в открытом ядре и что в Enterprise</p>
    <div class="sh-table-wrap">
      <table class="sh-table sh-table--features">
        <thead>
          <tr>
            <th scope="col" class="sh-feat-col">Возможность</th>
            <th scope="col">Ядро <span class="sh-col-sub">бесплатно</span></th>
            <th scope="col">Enterprise <span class="sh-col-sub">лицензия</span></th>
          </tr>
        </thead>
        <tbody>
          {featureRows.map((row) => (
            <tr>
              <th scope="row">{row.f}</th>
              <td class={row.core ? 'is-yes' : 'is-no'}>
                <span class="sr-only">{row.core ? 'Включено' : 'Не включено'}</span>
                <span aria-hidden="true">{row.core ? '✓' : '—'}</span>
              </td>
              <td class={row.ent ? 'is-yes' : 'is-no'}>
                <span class="sr-only">{row.ent ? 'Включено' : 'Не включено'}</span>
                <span aria-hidden="true">{row.ent ? '✓' : '—'}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <div class="sh-faq reveal-up">
    <p class="sh-block-label">Вопросы о самостоятельном хостинге</p>
    <div class="sh-faq-grid">
      {faqs.map((item) => (
        <div class="sh-faq-item">
          <h3 class="sh-faq-q">{item.q}</h3>
          <p class="sh-faq-a">{item.a}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sh { padding-top: 0; }

  .sh-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }
  .sh-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  .sh-card--featured {
    border-color: var(--pill-border);
    background: var(--brand-wash);
    box-shadow: var(--shadow-frame, none);
  }
  .sh-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .sh-name {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .sh-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--brand-strong);
    border: 1px solid var(--pill-border);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.5rem;
    white-space: nowrap;
  }
  .sh-amount {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .sh-amt {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .sh-period {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--fg-faint);
  }
  .sh-blurb {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }
  .sh-specs {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }
  .sh-specs li {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg);
    padding-left: 1.1rem;
    position: relative;
  }
  .sh-specs li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--brand);
  }
  .sh-cta {
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--cta-ghost-border);
    color: var(--fg);
    background: transparent;
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    transition: border-color var(--dur) var(--ease-out), background var(--dur) var(--ease-out);
  }
  .sh-cta:hover { border-color: var(--brand); background: var(--surface); }
  .sh-cta--primary {
    background: var(--cta-bg);
    border-color: transparent;
    color: var(--cta-fg);
  }
  .sh-cta--primary:hover { background: var(--cta-bg-hover); }

  .sh-block-label {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-faint);
  }

  /* Commercial license — a slim strip, not a co-equal card. */
  .sh-commercial {
    margin: 1rem 0 0;
    padding: 0.9rem 1.15rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface-sunk);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }
  .sh-commercial-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg);
    margin-right: 0.5rem;
  }
  .sh-commercial-link {
    color: var(--brand-strong);
    text-decoration: none;
    white-space: nowrap;
  }
  .sh-commercial-link:hover { text-decoration: underline; }

  .sh-matrix, .sh-features, .sh-faq { margin-top: 2.5rem; }

  /* Map table: two tiers × two run-modes. Row header carries a dim sub-label. */
  .sh-row-sub {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--fg-faint);
    margin-top: 0.15rem;
  }
  .sh-table--map tbody th { width: 30%; }

  .sh-table-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .sh-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .sh-table th, .sh-table td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .sh-table tr:last-child th, .sh-table tr:last-child td { border-bottom: none; }
  .sh-table thead th {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-soft);
    font-weight: 600;
    background: var(--surface-sunk);
  }
  .sh-table tbody th {
    color: var(--fg);
    font-weight: 500;
  }
  .sh-table tbody td { color: var(--fg-soft); }
  .sh-corner { background: var(--surface-sunk); border-bottom: 1px solid var(--border); }

  .sh-col-sub {
    display: block;
    font-size: var(--text-xs);
    font-weight: 400;
    text-transform: none;
    letter-spacing: normal;
    color: var(--fg-faint);
  }
  .sh-table--features tbody th { font-weight: 400; }
  .sh-table--features td { text-align: center; font-size: var(--text-base); width: 9rem; }
  .sh-feat-col { width: auto; }
  .sh-table .is-yes { color: var(--brand-strong); }
  .sh-table .is-no { color: var(--fg-faint); }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .sh-note {
    margin: 0.85rem 0 0;
    font-size: var(--text-xs);
    color: var(--fg-faint);
  }

  .sh-faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem 1.5rem;
  }
  .sh-faq-item {
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  .sh-faq-q {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--fg);
  }
  .sh-faq-a {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--fg-soft);
  }

  @media (max-width: 900px) {
    .sh-cards { grid-template-columns: 1fr; }
    .sh-faq-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 620px) {
    .sh-table--features td { width: 4.5rem; }
    .sh-table th, .sh-table td { padding: 0.6rem 0.7rem; }
  }
</style>
