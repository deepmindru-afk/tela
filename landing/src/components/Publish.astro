---
// §8b — Publish. A space flipped to public becomes a no-login, magazine-style
// blog (docs/public-spaces.md): masthead + post cards, RSS, OG/JSON-LD/sitemap,
// and an author home at /u/{handle}. Same markdown underneath — nothing
// duplicated. Read-only by design: publishing grants no write access.
const feats = [
  'Публичное чтение без входа',
  'RSS-лента для каждого пространства',
  'OG, JSON-LD и sitemap для SEO',
  'Страница автора по адресу /u/handle',
];
---
<section id="publish" class="section">
  <div class="section-head reveal-up">
    <p class="kicker"><span class="kicker-dot"></span>Публикация</p>
    <h2 class="h2">Ваша вики удваивается как публичный сайт.</h2>
    <p class="lede">
      Сделайте пространство публичным, и оно станет <strong>блогом в журнальном стиле без входа</strong> — ваши
      документы, журнал изменений или руководство в открытом вебе, с RSS и SEO из коробки. В основе всё тот же
      простой markdown; ничего не дублируется, ничего не экспортируется.
    </p>
  </div>

  <div class="pub-wrap reveal-up">
    <!-- Blog front-page mock -->
    <div class="pub-frame" role="img" aria-label="Публичное пространство, отображённое как главная страница блога: шапка и карточки публикаций">
      <div class="pub-mast">
        <span class="pub-avatar" aria-hidden="true">E</span>
        <span class="pub-id">
          <span class="pub-name">Engineering</span>
          <span class="pub-stand">Как мы создаём и развиваем tela.</span>
        </span>
        <span class="pub-rss" aria-hidden="true">RSS</span>
      </div>
      <div class="pub-cards">
        <article class="pub-card pub-lead">
          <span class="pub-cover" aria-hidden="true"><span class="pub-mono">P</span></span>
          <span class="pub-meta">6 июн · 4 мин · инцидент</span>
          <span class="pub-title">Postmortem: сбой кэша</span>
          <span class="pub-ex">Что сломалось, почему p99 вырос втрое и какую защиту мы внедрили.</span>
        </article>
        <article class="pub-card">
          <span class="pub-meta">28 мая · 6 мин · RFC</span>
          <span class="pub-title">RFC: гибридный поиск</span>
          <span class="pub-ex">Объединение ключевого и векторного поиска по фрагментам с учётом заголовков.</span>
        </article>
      </div>
    </div>

    <!-- Capabilities -->
    <ul class="pub-feats">
      {feats.map((f) => (
        <li>
          <svg class="tick" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          <span>{f}</span>
        </li>
      ))}
      <li class="pub-note">
        Только для чтения — публикация пространства не даёт прав на запись. Владелец включает; можно отключить в любой момент.
      </li>
    </ul>
  </div>
</section>

<style>
  .section-head .lede strong { color: var(--fg); font-weight: 600; }

  .pub-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
  }
  @media (min-width: 860px) {
    .pub-wrap { grid-template-columns: 1.5fr 1fr; gap: 2.5rem; }
  }

  /* ── blog front-page mock ─────────────────────────────────────────── */
  .pub-frame {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-frame, none);
    overflow: hidden;
  }
  .pub-mast {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1.1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface-sunk);
  }
  .pub-avatar {
    width: 2.25rem; height: 2.25rem; flex: none;
    display: grid; place-items: center;
    border-radius: var(--radius-md);
    background: var(--brand-wash);
    border: 1px solid var(--pill-border);
    font-family: var(--font-display); font-weight: 600;
    color: var(--brand-strong);
  }
  .pub-id { display: flex; flex-direction: column; gap: 0.1rem; min-width: 0; flex: 1; }
  .pub-name {
    font-family: var(--font-display); font-weight: 600;
    letter-spacing: var(--tracking-tight); color: var(--fg);
  }
  .pub-stand { font-size: var(--text-sm); color: var(--fg-faint); }
  .pub-rss {
    flex: none;
    font-family: var(--font-mono); font-size: var(--text-xs);
    letter-spacing: 0.08em;
    color: var(--accent);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 0.15rem 0.45rem;
  }

  .pub-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding: 1.25rem;
  }
  .pub-card { display: flex; flex-direction: column; gap: 0.4rem; min-width: 0; }
  .pub-cover {
    position: relative;
    display: block;
    aspect-ratio: 16 / 7;
    border-radius: var(--radius-md);
    margin-bottom: 0.35rem;
    overflow: hidden;
    background:
      linear-gradient(135deg, var(--brand-wash), var(--surface-sunk)),
      repeating-linear-gradient(0deg, var(--border) 0 1px, transparent 1px 13px),
      repeating-linear-gradient(90deg, var(--border) 0 1px, transparent 1px 13px);
    border: 1px solid var(--border);
  }
  .pub-mono {
    position: absolute; right: -0.25rem; bottom: -1.1rem;
    font-family: var(--font-display); font-weight: 700;
    font-size: 4.5rem; line-height: 1;
    color: var(--brand);
    opacity: 0.16;
  }
  .pub-meta {
    font-family: var(--font-mono); font-size: var(--text-xs);
    color: var(--fg-faint);
  }
  .pub-title {
    font-family: var(--font-display); font-weight: 600;
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--fg);
  }
  .pub-ex { font-size: var(--text-sm); line-height: var(--leading-snug); color: var(--fg-soft); }

  @media (max-width: 560px) {
    .pub-cards { grid-template-columns: 1fr; }
    .pub-lead .pub-cover { aspect-ratio: 16 / 6; }
  }

  /* ── capability list ──────────────────────────────────────────────── */
  .pub-feats { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.85rem; }
  .pub-feats li {
    display: flex; align-items: flex-start; gap: 0.55rem;
    font-size: var(--text-base); color: var(--fg-soft);
  }
  .pub-feats .tick { color: var(--brand); flex: none; margin-top: 0.2rem; }
  .pub-note {
    margin-top: 0.25rem; padding-top: 0.85rem;
    border-top: 1px solid var(--border);
    font-size: var(--text-sm); color: var(--fg-faint);
  }
</style>
