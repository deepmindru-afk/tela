---
// /compare/ — hub linking every comparison page. Internal-linking + crawl entry
// for the /compare/<slug> set. Prose layout, token-only.
import Prose from '../../layouts/Prose.astro';
import { competitors } from '../../data/compare';
---

<Prose
  title="Сравнение tela — open-source, работает на вашем сервере, командная вики для ИИ"
  description="Сравнение tela с Notion, Confluence, Outline, GitBook, Docmost, BookStack, Wiki.js и другими — честно, с указанием, в чём каждый из них всё ещё лучше."
  kicker="Сравнение"
  heading="Сравнение tela с альтернативами"
  updated="30 июня 2026"
>
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'CollectionPage',
        '@id': 'https://telawiki.com/compare/#page',
        name: 'Сравнение tela с альтернативами',
        url: 'https://telawiki.com/compare/',
        inLanguage: 'ru',
        isPartOf: { '@id': 'https://telawiki.com/#website' },
        about: { '@id': 'https://telawiki.com/#software' },
      },
      {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Главная', item: 'https://telawiki.com/' },
          { '@type': 'ListItem', position: 2, name: 'Сравнение', item: 'https://telawiki.com/compare/' },
        ],
      },
    ],
  })} />

  <p class="lead">
    tela — это open-source (AGPL), работает на вашем сервере, командная вики, работающая с Markdown «из коробки»:\n
    ваша документация остаётся в виде канонического Markdown, к которому вы владеете правами, агенты читают и пишут её через
    встроенный MCP-сервер, а Atlas генерирует документацию с цитатами и проверкой покрытия из
    ваших репозиториев git и Jira. Вот как она соотносится с инструментами, которыми вы бы
    пользовались иначе — включая то, в чём каждый из них всё ещё лучше.
  </p>

  <ul class="tool-grid">
    {competitors.map((c) => (
      <li>
        <a href={`/compare/${c.slug}/`}>tela vs {c.name}</a>
        <span class="desc">{c.heading}</span>
      </li>
    ))}
  </ul>

  <h2>Краткая версия</h2>
  <p>
    Большинство из них — хорошие инструменты. Уникальность tela — в двух вещах: это полностью open-source и работает на вашем сервере с каноническим Markdown,
    которым вы владеете, и <strong>Atlas</strong> генерирует документацию из вашего кода и отслеживает,
    чтобы она не расходилась — что большинство вики оставляет на усмотрение человеческой дисциплины. Встроенный MCP-сервер — это сила,
    которой tela делится с несколькими из них, а не монополия.
  </p>
  <p>
    Попробуйте: запустите сами под лицензией AGPL или начните с бесплатного облачного тарифа на
    <a href="/">telawiki.com</a>.
  </p>
</Prose>
