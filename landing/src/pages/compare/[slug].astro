---
// /compare/<slug> — one honest comparison page per competitor, data-driven from
// src/data/compare.ts. Mirrors the /mcp page: Prose layout + per-page TechArticle
// + BreadcrumbList JSON-LD. Token-only styles (the landing-gate enforces it).
import Prose from '../../layouts/Prose.astro';
import { competitors } from '../../data/compare';
import type { Competitor } from '../../data/compare';

export function getStaticPaths() {
  return competitors.map((c) => ({ params: { slug: c.slug }, props: { c } }));
}

const { c } = Astro.props as { c: Competitor };
const url = `https://tla.portalos.ru/compare/${c.slug}/`;

// FAQ derived from the same vetted copy shown on the page (no invented facts) —
// drives both an on-page FAQ section and FAQPage JSON-LD for rich results.
const faqs = [
  {
    q: `Является ли tela хорошей альтернативой ${c.name}?`,
    a: `Да. ${c.whySwitch[0]} portal — это open-source (AGPL-3.0), работает на вашем сервере, работает с Markdown «из коробки», и имеет встроенный MCP-сервер, позволяющий AI-агентам читать и писать вашу документацию.`,
  },
  {
    q: `Могу ли я запустить tela на своём сервере и подключить AI-агентов?`,
    a: `Да. Запустите tela на своём сервере бесплатно (AGPL-3.0) или начните с бесплатного облачного тарифа. Встроенный MCP-сервер предоставляет 39 инструментов, так что агенты вроде Claude читают и пишут вашу вики напрямую.`,
  },
  {
    q: `Когда ${c.name} является лучшим выбором?`,
    a: c.whenBetter,
  },
];
---

<Prose
  title={c.seoTitle}
  description={c.metaDescription}
  kicker="Сравнение"
  heading={c.heading}
  updated="30 июня 2026"
>
  <script type="application/ld+json" is:inline slot="head" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'TechArticle',
        '@id': `${url}#article`,
        headline: c.heading,
        description: c.metaDescription,
        url,
        inLanguage: 'ru',
        dateModified: '2026-06-30',
        author: { '@id': 'https://tla.portalos.ru/#org' },
        publisher: { '@id': 'https://tla.portalos.ru/#org' },
        about: { '@id': 'https://tla.portalos.ru/#software' },
        isPartOf: { '@id': 'https://tla.portalos.ru/#website' },
      },
      {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Главная', item: 'https://tla.portalos.ru/' },
          { '@type': 'ListItem', position: 2, name: 'Сравнение', item: 'https://tla.portalos.ru/compare/' },
          { '@type': 'ListItem', position: 3, name: `tela vs ${c.name}`, item: url },
        ],
      },
      {
        '@type': 'FAQPage',
        '@id': `${url}#faq`,
        mainEntity: faqs.map((f) => ({
          '@type': 'Question',
          name: f.q,
          acceptedAnswer: { '@type': 'Answer', text: f.a },
        })),
      },
    ],
  })} />

  <p class="lead">{c.lead}</p>

  <h2>tela и {c.name} — краткий обзор</h2>
  <div class="cmp-scroll">
    <table class="cmp">
      <caption class="sr-only">Сравнение функций tela и {c.name}.</caption>
      <thead>
        <tr>
          <th scope="col">Функция</th>
          <th scope="col" class="is-tela">tela</th>
          <th scope="col">{c.name}</th>
        </tr>
      </thead>
      <tbody>
        {c.rows.map((r) => (
          <tr>
            <th scope="row">{r.feature}</th>
            <td class="is-tela" data-label="tela">{r.tela}</td>
            <td data-label={c.name}>{r.them}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>Почему команды переходят на tela</h2>
  <ul>
    {c.whySwitch.map((w) => <li>{w}</li>)}
  </ul>

  <h2>Когда {c.name} — лучший выбор</h2>
  <p>{c.whenBetter}</p>

  <h2>Часто задаваемые вопросы</h2>
  {faqs.map((f) => (
    <Fragment>
      <h3>{f.q}</h3>
      <p>{f.a}</p>
    </Fragment>
  ))}

  <h2>Попробуйте tela</h2>
  <p>
    portal — это open-source (AGPL) командная вики, работающая на вашем сервере. Запустите её сами или начните
    с бесплатного облачного тарифа на <a href="/">telawiki.com</a>. Ознакомьтесь с
    <a href="/mcp/">документацией MCP-сервера</a> для подключения агентов или
    <a href="/compare/">сравните tela с другими инструментами</a>.
  </p>

  <p class="source">{c.source} Информация о tela актуальна на июнь 2026 г.</p>
</Prose>

<style>
  /* Token-only: colors via var(--*), spacing on the 4px grid (rem), like Prose. */
  .cmp-scroll {
    overflow-x: auto;
    margin: 1.5rem 0 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .cmp {
    width: 100%;
    min-width: 34rem;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .cmp caption.sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
  .cmp th,
  .cmp td {
    text-align: left;
    vertical-align: top;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  .cmp thead th {
    color: var(--fg);
    font-weight: 600;
    background: var(--surface-sunk);
    white-space: nowrap;
  }
  .cmp tbody th[scope='row'] {
    color: var(--fg);
    font-weight: 600;
    width: 12rem;
  }
  .cmp td { color: var(--fg-soft); }
  .cmp tbody tr:last-child th,
  .cmp tbody tr:last-child td { border-bottom: 0; }
  /* tela's column is the earned highlight. */
  .cmp .is-tela { background: var(--surface); }
  .cmp thead th.is-tela { color: var(--brand-strong); }

  .source {
    margin-top: 2.5rem;
    font-size: var(--text-xs);
    color: var(--fg-faint);
  }
</style>
