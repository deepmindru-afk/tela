---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import Atlas from '../components/Atlas.astro';
import AgentWeave from '../components/AgentWeave.astro';
import AskDocs from '../components/AskDocs.astro';
import ActThread from '../components/ActThread.astro';
import Pivot from '../components/Pivot.astro';
import EditorShowcase from '../components/EditorShowcase.astro';
import ShowcaseBento from '../components/ShowcaseBento.astro';
import Compare from '../components/Compare.astro';
import Security from '../components/Security.astro';
import Publish from '../components/Publish.astro';
import Sheets from '../components/Sheets.astro';
import Decks from '../components/Decks.astro';
import Pricing from '../components/Pricing.astro';
import Credibility from '../components/Credibility.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Base ogDescription="Командная вики, которая документирует сама себя. Укажите Atlas источник — git-репозиторий или Jira-проект — и он напишет вики с цитатами, проверит покрытие и будет поддерживать её в актуальном состоянии. Ваши агенты ищут по смыслу, читают, пишут и цитируют страницы из Claude и ChatGPT. Редактирование в реальном времени и разграничение доступа, с SSO в Enterprise. Ваш Markdown, в облаке или на вашем сервере.">
  <SiteHeader />
  <main id="main">
    <Hero />
    <Atlas />
    <ActThread />
    <AskDocs />
    <ActThread />
    <AgentWeave />
    <Pivot />
    <EditorShowcase />
    <ShowcaseBento />
    <Sheets />
    <Decks />
    <Compare />
    <Security />
    <Publish />
    <Pricing />
    <Credibility />
    <Faq />
    <FinalCta />
  </main>
  <SiteFooter />
</Base>
