---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Pricing from '../components/Pricing.astro';
import SelfHostPricing from '../components/SelfHostPricing.astro';
import FinalCta from '../components/FinalCta.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Base
  title="Цены — tela"
  description="Простая облачная лестница — Free, Personal, Team и Enterprise — с управляемым ИИ включён; тарифы влияют на лимиты (источники Atlas, месячные ответы ИИ) и управление командой, а не на функции. Или хостите самостоятельно: Community — весь продукт, бесплатно и open source, с приватным ИИ; Enterprise добавляет SSO, аудит и управление на вашей инфраструктуре. Новые облачные аккаунты начинают с 30-дневного пробного периода Personal."
  ogDescription="Цены tela — простая облачная лестница (Free, Personal, Team, Enterprise) с управляемым ИИ включён, или хостите бесплатно с приватным ИИ. Каждый план включает Atlas, семантический поиск, «Спросите документы», коннектор MCP, синхронизацию WebDAV и редактирование в реальном времени. Enterprise добавляет SSO, SCIM и аудит в облаке или самостоятельно."
>
  <SiteHeader />
  <main id="main">
    <Pricing />
    <SelfHostPricing />
    <FinalCta />
  </main>
  <SiteFooter />
</Base>
