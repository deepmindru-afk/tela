---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Pricing from '../components/Pricing.astro';
import FinalCta from '../components/FinalCta.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Base
  title="Pricing — tela"
  description="Simple plans for individuals and teams. Personal Free & Plus; organization Free, Team, and Enterprise. Tiers change limits — spaces, storage, and monthly AI answers — not features. Every plan ships semantic search, ask your docs, the MCP connector, WebDAV sync, and real-time editing. New accounts start on a 30-day Plus trial. Self-host free and open."
  ogDescription="tela pricing — personal and organization tiers, or self-host it free. Every plan includes semantic search, ask your docs with citations, the MCP connector for Claude & ChatGPT, WebDAV sync, and real-time editing. New accounts get a 30-day Plus trial."
>
  <SiteHeader />
  <main id="main">
    <Pricing />
    <FinalCta />
  </main>
  <SiteFooter />
</Base>
