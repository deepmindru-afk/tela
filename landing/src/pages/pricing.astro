---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Pricing from '../components/Pricing.astro';
import SelfHostPricing from '../components/SelfHostPricing.astro';
import FinalCta from '../components/FinalCta.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Base
  title="Pricing — tela"
  description="One simple cloud ladder — Free, Personal, Team, and Enterprise — with managed AI included; tiers change limits (Atlas sources, monthly AI answers) and team controls, not features. Or self-host it: Community is the whole product, free and open, with bring-your-own AI; Enterprise adds SSO, audit and governance on your own infrastructure. New cloud accounts start on a 30-day Personal trial."
  ogDescription="tela pricing — a simple cloud ladder (Free, Personal, Team, Enterprise) with managed AI included, or self-host it free with bring-your-own AI. Every plan ships Atlas, semantic search, ask-your-docs, the MCP connector, WebDAV sync and real-time editing. Enterprise adds SSO, SCIM and audit on cloud or self-host."
>
  <SiteHeader />
  <main id="main">
    <Pricing />
    <SelfHostPricing />
    <FinalCta />
  </main>
  <SiteFooter />
</Base>
